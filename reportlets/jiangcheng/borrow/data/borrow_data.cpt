<!-- ==================== 批量导入（原 equipment_batch_data.cpt 合并） ==================== -->

<!-- 批量写入临时表 -->
<TableData name="batch_insert" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter><Attributes name="p_import_id"/><O><![CDATA[]]></O></Parameter>
<Parameter><Attributes name="p_data_json"/><O><![CDATA[]]></O></Parameter>
<Parameter><Attributes name="p_start_row"/><O><![CDATA[1]]></O></Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName><![CDATA[common_db]]></DatabaseName>
</Connection>
<Query><![CDATA[
CALL common_db.sp_batch_import('${p_import_id}', 'equipment', '${p_data_json}', ${p_start_row})
]]></Query>
<PageQuery><![CDATA[]]></PageQuery>
</TableData>

<!-- 校验导入数据 -->
<TableData name="validate" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter><Attributes name="p_import_id"/><O><![CDATA[]]></O></Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName><![CDATA[common_db]]></DatabaseName>
</Connection>
<Query><![CDATA[
CALL common_db.sp_equipment_import_validate('${p_import_id}')
]]></Query>
<PageQuery><![CDATA[]]></PageQuery>
</TableData>

<!-- 提交到业务表 -->
<TableData name="commit" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter><Attributes name="p_import_id"/><O><![CDATA[]]></O></Parameter>
<Parameter><Attributes name="p_mode"/><O><![CDATA[VALID_ONLY]]></O></Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName><![CDATA[common_db]]></DatabaseName>
</Connection>
<Query><![CDATA[
CALL common_db.sp_equipment_import_commit('${p_import_id}', '${p_mode}')
]]></Query>
<PageQuery><![CDATA[]]></PageQuery>
</TableData>

<!-- 查询错误记录 -->
<TableData name="errors" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter><Attributes name="p_import_id"/><O><![CDATA[]]></O></Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName><![CDATA[common_db]]></DatabaseName>
</Connection>
<Query><![CDATA[
SELECT
    row_no,
    str_01 AS asset_no,
    str_02 AS equipment_name,
    str_03 AS equipment_type,
    error_msg
FROM temp_import
WHERE import_id = '${p_import_id}' AND is_valid = 0
ORDER BY row_no
LIMIT 100
]]></Query>
<PageQuery><![CDATA[]]></PageQuery>
</TableData>

<!-- 导入统计 -->
<TableData name="stats" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter><Attributes name="p_import_id"/><O><![CDATA[]]></O></Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName><![CDATA[common_db]]></DatabaseName>
</Connection>
<Query><![CDATA[
SELECT
    COUNT(*) AS total,
    SUM(CASE WHEN is_valid = 1 THEN 1 ELSE 0 END) AS valid_count,
    SUM(CASE WHEN is_valid = 0 THEN 1 ELSE 0 END) AS error_count
FROM temp_import
WHERE import_id = '${p_import_id}'
]]></Query>
<PageQuery><![CDATA[]]></PageQuery>
</TableData>

</TableDataMap>

